{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicenow-knowledge-builder/schemas/statistics.schema.json",
  "title": "statistics.json",
  "description": "Aggregated session counters (Export Engine, section 9.11).",
  "type": "object",
  "required": ["schema_version", "session_id"],
  "properties": {
    "schema_version": { "type": "string" },
    "session_id": { "type": "string", "format": "uuid" },
    "total_pages": { "type": "integer", "minimum": 0 },
    "total_elements": { "type": "integer", "minimum": 0 },
    "total_selectors": { "type": "integer", "minimum": 0 },
    "total_screenshots": { "type": "integer", "minimum": 0 },
    "total_events": { "type": "integer", "minimum": 0 },
    "total_logs": { "type": "integer", "minimum": 0 },
    "capture_duration_seconds": { "type": ["number", "null"] },
    "export_duration_seconds": { "type": ["number", "null"] },
    "error_count": { "type": "integer", "minimum": 0 },
    "warning_count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
